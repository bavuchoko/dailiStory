# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# 안정적인 iOS 빌드를 위해 New Architecture 비활성화
ENV['RCT_NEW_ARCH_ENABLED'] = '0'

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'dailyStory' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Xcode/clang 최신 버전에서 일부 Pod가 경고를 에러로 처리하며 빌드가 실패하는 케이스가 있습니다.
    # (예: -Wnon-modular-include-in-framework-module, -Wmismatched-parameter-types)
    # 앱 타겟이 아니라 Pods 타겟에만 완화 설정을 적용합니다.
    extra_warning_flags = [
      '-Wno-non-modular-include-in-framework-module',
      '-Wno-mismatched-parameter-types',
    ]

    installer.pods_project.targets.each do |t|
      t.build_configurations.each do |config|
        config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'

        # OTHER_CFLAGS는 배열일 수 있음 — 문자열로 합치면 "[ -DRCT_REMOVE_LEGACY_ARCH=1," 같은
        # 잘못된 플래그가 생겨 PromisesObjC 등 Pod 빌드가 실패합니다.
        flags = config.build_settings['OTHER_CFLAGS'] || '$(inherited)'
        flags = flags.is_a?(Array) ? flags.dup : [flags.to_s]
        extra_warning_flags.each do |flag|
          next if flags.any? { |f| f.to_s.include?(flag) }
          flags << flag
        end
        config.build_settings['OTHER_CFLAGS'] = flags
      end
    end
  end
end
